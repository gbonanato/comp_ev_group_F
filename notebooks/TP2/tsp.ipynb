    "import random\n",
    "\n",
    "chrm_size = 6\n",
    "chrm = random.sample(range(1, chrm_size), (chrm_size - 1))\n",
    "chrm.insert(0, 0)\n",
    "chrm.append(0)\n",
    "chrm"
   ]
  },
